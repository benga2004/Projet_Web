{% extends 'layout/base.html.twig' %}

{% block title %}Ma Wishlist - StageHub{% endblock %}

{% block content %}
<div class="wishlist-page">

    <div class="legal-hero">
        <div class="legal-hero-icon"><i class="fas fa-bookmark" aria-hidden="true"></i></div>
        <h1>Ma Wishlist</h1>
        <p>
            {% if offres|default([])|length == 0 %}
                Vous n'avez pas encore sauvegardé d'offre.
            {% else %}
                {{ offres|length }} offre{{ offres|length > 1 ? 's' : '' }} sauvegardée{{ offres|length > 1 ? 's' : '' }}
            {% endif %}
        </p>
    </div>

    {% if offres|default([])|length == 0 %}
    <div class="wishlist-empty">
        <i class="far fa-bookmark"></i>
        <p>Parcourez les offres et cliquez sur <i class="fas fa-bookmark" style="color:#667eea"></i> pour les sauvegarder ici.</p>
        <a href="{{ base_url }}offres" class="btn btn-primary">Voir les offres</a>
    </div>
    {% else %}
    <div class="wishlist-grid">
        {% for offre in offres %}
        <div class="offer-card" id="wl-card-{{ offre.id }}">
            <div class="offer-card-header">
                <h2>{{ offre.titre }}</h2>
                <button class="wishlist-btn active"
                        type="button"
                        data-offre="{{ offre.id }}"
                        title="Retirer de la wishlist">
                    <i class="fas fa-bookmark"></i>
                </button>
            </div>
            <p class="company"><i class="fas fa-building"></i> {{ offre.entreprise_nom }}</p>
            <p><i class="fas fa-map-marker-alt"></i> {{ offre.ville }}</p>
            <p><i class="fas fa-clock"></i> {{ offre.duree }}</p>
            <p><i class="fas fa-tag"></i> {{ offre.domaine }}</p>
            <div class="offer-card-footer">
                <a class="details-btn" href="{{ base_url }}offres/detail?id={{ offre.id }}">Voir le détail</a>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

</div>
{% endblock %}

{% block extra_js %}
<script>
// Retire la carte de la wishlist quand on clique sur le bookmark depuis cette page
// On utilise e.stopPropagation() pour empêcher le handler global (script.js) de se déclencher aussi
document.querySelectorAll('.wishlist-page .wishlist-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();

        var self    = this;
        var offreId = self.dataset.offre;
        var card    = document.getElementById('wl-card-' + offreId);
        var fd      = new FormData();
        fd.append('offre_id', offreId);

        fetch('{{ base_url }}wishlist/toggle', { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.error) {
                    console.error('Wishlist error:', data.error);
                    return;
                }
                if (!data.in_wishlist && card) {
                    card.style.transition = 'opacity .3s, transform .3s';
                    card.style.opacity    = '0';
                    card.style.transform  = 'scale(0.95)';
                    setTimeout(function() {
                        card.remove();
                        // Met à jour le compteur
                        var remaining = document.querySelectorAll('.wishlist-grid .offer-card').length;
                        var heroP = document.querySelector('.wishlist-page .legal-hero p');
                        if (remaining === 0) {
                            location.reload();
                        } else if (heroP) {
                            heroP.textContent = remaining + ' offre' + (remaining > 1 ? 's' : '') + ' sauvegardée' + (remaining > 1 ? 's' : '');
                        }
                    }, 300);
                }
            })
            .catch(function(err) { console.error('Wishlist error:', err); });
    });
});
</script>
{% endblock %}
