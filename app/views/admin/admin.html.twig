{% extends 'layout/base.html.twig' %}

{% block title %}Dashboard Admin - StageHub{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{{ base_url }}css/admin.css?v=3">
{% endblock %}

{% block page_header %}
<header class="header">
    <div class="header-logo">
        <div class="header-logo-icon">S</div>
        StageHub
    </div>
    <div class="header-right">
        <div class="header-user">
            <div>{{ session.user_prenom ?? 'Admin' }}</div>
            <span class="role-badge">Administrateur</span>
        </div>
        <a href="{{ base_url }}deconnexion" class="btn-logout">&#x23FB;</a>
    </div>
</header>
{% endblock %}

{% block content %}
<section class="admin-dashboard">
    <div class="admin-hero">
        <div>
            <span class="admin-kicker">Espace administration</span>
            <h1>Bonjour, {{ adminName }} 👋</h1>
            <p>Voici l'état actuel de la plateforme et les points d'entrée utiles pour l'administration.</p>
        </div>
        <div class="admin-hero-actions">
            <a href="{{ base_url }}admin/entreprises" class="admin-btn admin-btn-primary">
                <i class="bi bi-buildings-fill"></i>
                Gérer les entreprises
            </a>
            <a href="{{ base_url }}offres" class="admin-btn admin-btn-secondary">
                <i class="bi bi-briefcase-fill"></i>
                Voir les offres
            </a>
        </div>
    </div>

    <div class="admin-stats-grid">
        {% for stat in stats %}
        <article class="admin-stat-card">
            <div class="admin-stat-icon"><i class="{{ stat.icon }}"></i></div>
            <div class="admin-stat-value">{{ stat.value }}</div>
            <div class="admin-stat-label">{{ stat.label }}</div>
            <p class="admin-stat-detail">{{ stat.detail }}</p>
        </article>
        {% endfor %}
    </div>

    <div class="admin-grid">
        <section class="admin-panel">
            <div class="admin-panel-head">
                <div>
                    <span class="admin-panel-kicker">Modules</span>
                    <h2>Accès rapides</h2>
                </div>
            </div>
            <div class="admin-modules-grid">
                {% for module in modules %}
                    {% if module.is_active %}
                    <a href="{{ module.href }}" class="admin-module-card">
                        <div class="admin-module-icon"><i class="{{ module.icon }}"></i></div>
                        <div class="admin-module-body">
                            <div class="admin-module-topline">
                                <h3>{{ module.title }}</h3>
                                <span class="admin-module-count">{{ module.count }}</span>
                            </div>
                            <p>{{ module.description }}</p>
                            <span class="admin-module-status">{{ module.status }}</span>
                        </div>
                    </a>
                    {% else %}
                    <div class="admin-module-card admin-module-card-disabled" aria-disabled="true">
                        <div class="admin-module-icon"><i class="{{ module.icon }}"></i></div>
                        <div class="admin-module-body">
                            <div class="admin-module-topline">
                                <h3>{{ module.title }}</h3>
                                <span class="admin-module-count">{{ module.count }}</span>
                            </div>
                            <p>{{ module.description }}</p>
                            <span class="admin-module-status admin-module-status-muted">{{ module.status }}</span>
                        </div>
                    </div>
                    {% endif %}
                {% endfor %}
            </div>
        </section>

        <section class="admin-panel">
            <div class="admin-panel-head">
                <div>
                    <span class="admin-panel-kicker">Comptes</span>
                    <h2>Répartition</h2>
                </div>
            </div>
            <div class="admin-summary-list">
                {% for item in accountSummary %}
                <div class="admin-summary-row">
                    <div class="admin-summary-label-wrap">
                        <span class="admin-summary-dot {{ item.tone }}"></span>
                        <span class="admin-summary-label">{{ item.label }}</span>
                    </div>
                    <strong>{{ item.value }}</strong>
                </div>
                {% endfor %}
            </div>
        </section>
    </div>

    <section class="admin-panel">
        <div class="admin-panel-head">
            <div>
                <span class="admin-panel-kicker">Utilisateurs</span>
                <h2>Derniers comptes</h2>
            </div>
        </div>
        {% if recentUsers is empty %}
            <p class="admin-empty">Aucun compte trouvé.</p>
        {% else %}
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Email</th>
                        <th>Rôle</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in recentUsers %}
                    <tr>
                        <td>{{ (user.prenom ~ ' ' ~ user.nom)|trim }}</td>
                        <td>{{ user.email }}</td>
                        <td>
                            <span class="admin-role-pill admin-role-{{ user.role }}">
                                {{ user.role|capitalize }}
                            </span>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </section>
</section>
{% endblock %}


